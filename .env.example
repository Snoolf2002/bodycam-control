# ── Bodycam Control Plane Environment ────────────────────────────────
# Copy this file to .env and fill in production values.

# HMAC secret for signing RTSP stream tokens (MUST change in production)
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING

# Session token for RTSP stream auth (get this from your camera settings/firmware)
SESSION_TOKEN=your-session-token-here

# Redis
REDIS_URL=redis://redis:6379/0
DEVICE_TTL_SECONDS=120

# TimescaleDB / PostgreSQL
DATABASE_URL=postgresql+asyncpg://bodycam:bodycam@timescaledb:5432/bodycam
POSTGRES_USER=bodycam
POSTGRES_PASSWORD=bodycam
POSTGRES_DB=bodycam

# TCP Telemetry Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=6608

# API
API_HOST=0.0.0.0
API_PORT=8001
